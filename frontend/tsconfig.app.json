{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Reglas de Limpieza y Calidad de Código (Linting) */
    "strict": false,                     /* Permite desarrollo flexible con los tipados de las peticiones HTTP */
    "noUnusedLocals": true,              /* Advierte si dejas variables declaradas sin usar */
    "noUnusedParameters": true,          /* Advierte si dejas parámetros de funciones sin usar */
    "noFallthroughCasesInSwitch": true,   /* Evita errores lógicos en bloques switch/case */
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}