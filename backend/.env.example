# ─── Base de datos PostgreSQL ────────────────────────────────────────────────
# Render.com (producción):
DATABASE_URL=postgresql://unahcu:PASSWORD@host.virginia-postgres.render.com/puma_conecta?sslmode=require

# Local (desarrollo con Docker Compose):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/puma_conecta

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=5000

# ─── JWT ─────────────────────────────────────────────────────────────────────
# IMPORTANTE: Cambiar en producción por un string largo y aleatorio
JWT_SECRET=cambia_esto_en_produccion_usa_openssl_rand_base64_64

# ─── CORS ────────────────────────────────────────────────────────────────────
# URL del frontend (React)
FRONTEND_URL=http://localhost:5185
